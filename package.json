{
  "name": "mimir",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "clean": "rm -rf .next",
    "build": "next build",
    "start": "next start",
    "start:railway": "next start -p $PORT",
    "oracle:solana": "tsx --env-file-if-exists=.env.local agents/oracle/solana.ts",
    "market-creator:solana": "tsx --env-file-if-exists=.env.local agents/market-creator/solana.ts",
    "council:solana": "tsx --env-file-if-exists=.env.local agents/council/solana.ts",
    "workers:solana": "concurrently --names oracle,creator,council,indexer --kill-others-on-fail -c blue,magenta,green,yellow \"npm:oracle:solana\" \"npm:market-creator:solana\" \"npm:council:solana\" \"npm:indexer:solana\"",
    "demo:solana": "tsx --env-file-if-exists=.env.local scripts/solana/demo-full-cycle.ts",
    "fund:agent": "tsx --env-file-if-exists=.env.local scripts/solana/agent-fund.ts",
    "test:smoke": "node --import tsx --test tests/node/api-validation.test.ts tests/node/claim-moderation-route.test.ts tests/node/claim-moderation-sanitize.test.ts tests/node/claim-quality.test.ts",
    "warm:vs-index": "tsx scripts/warm-vs-index.ts",
    "system:status": "tsx --env-file-if-exists=.env.local scripts/solana/system-status.ts",
    "system:fund": "tsx --env-file-if-exists=.env.local scripts/solana/system-status.ts --fund",
    "init:solana": "tsx --env-file-if-exists=.env.local scripts/solana/initialize.ts",
    "indexer:solana": "tsx --env-file-if-exists=.env.local agents/indexer/solana.ts",
    "start:all": "concurrently -n web,workers -c cyan,green \"next start -p $PORT\" \"npm run workers:solana\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@coral-xyz/anchor": "^0.32.1",
    "@fontsource/maple-mono": "^5.2.6",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.15.3",
    "@neondatabase/serverless": "^1.1.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.100.10",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.383.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "nextjs-toploader": "^3.9.17",
    "ogl": "^1.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "sonner": "^1.7.0",
    "tsx": "^4.19.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.0",
    "postcss": "^8",
    "solc": "^0.8.28",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  }
}
