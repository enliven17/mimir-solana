# =============================================================================
# Mimir — environment variables (copy to .env.local; never commit secrets)
# =============================================================================

# ── Arc contract ──────────────────────────────────────────────────────────────
# Deployed Mimir.sol address on Arc Testnet (chain 5042002)
# Set automatically by: npm run deploy:contract
# NEXT_PUBLIC_CONTRACT_ADDRESS=0x...

# Block number where the contract was deployed. Arc public RPC limits
# eth_getLogs to a 10k-block range, so the agents/stats pages paginate
# starting from this block. Falls back to a hard-coded constant if unset.
# NEXT_PUBLIC_DEPLOY_BLOCK=42719056

# Arc RPC endpoint override (default: https://rpc.testnet.arc.network)
# Custom endpoint override:
# NEXT_PUBLIC_ARC_RPC=https://arc-node.thecanteenapp.com/<your-token>
# ARC_RPC=https://arc-node.thecanteenapp.com/<your-token>  # server-only

# ── Wallet connect ────────────────────────────────────────────────────────────
# WalletConnect Cloud project id — powers the QR code path in the ConnectKit
# modal so any of the 380+ WC-compatible mobile wallets can connect. Get one
# free at https://cloud.walletconnect.com (~30 second signup).
# Without this var the modal still shows browser-extension wallets (MetaMask,
# Coinbase, Rainbow, Phantom, Trust, Brave, OKX, etc.) — only the mobile QR
# entry is hidden.
# NEXT_PUBLIC_WC_PROJECT_ID=

# ── Circle stack ──────────────────────────────────────────────────────────────
# Circle developer credentials (https://console.circle.com)
#   • API Key   — Circle Wallets (W3S) + Circle Contracts
#   • Kit Key   — App Kit + Swap Kit (currently used for CCTP/Gateway proxies)
#   • Entity Secret — generated locally via: npx tsx scripts/circle-entity-secret.ts
#                    The ciphertext from that script must be registered ONCE in
#                    Console → Wallets → Dev Controlled → Configurator.
# CIRCLE_API_KEY=TEST_API_KEY:...
# CIRCLE_KIT_KEY=KIT_KEY:...
# CIRCLE_ENTITY_SECRET=<64-hex>

# W3S developer-controlled wallets for the two Mimir agents.
# Created automatically by: npx tsx scripts/circle-create-wallets.ts
# CIRCLE_WALLET_SET_ID=
# CIRCLE_ORACLE_WALLET_ID=
# CIRCLE_ORACLE_ADDRESS=0x...
# CIRCLE_CREATOR_WALLET_ID=
# CIRCLE_CREATOR_ADDRESS=0x...

# ── Oracle AI agent ───────────────────────────────────────────────────────────
# The oracle no longer holds a local private key — it signs via Circle W3S.
# Required env: CIRCLE_API_KEY, CIRCLE_ENTITY_SECRET,
#               CIRCLE_ORACLE_WALLET_ID, CIRCLE_ORACLE_ADDRESS,
#               + ONE of GEMINI_API_KEY / ANTHROPIC_API_KEY

# LLM provider — only ONE key is needed; Gemini is preferred when both are set.
# Force a specific provider with LLM_PROVIDER=gemini|anthropic.
# Override the default model with ORACLE_LLM_MODEL.
# GEMINI_API_KEY=...                       # https://aistudio.google.com/apikey
# ANTHROPIC_API_KEY=sk-ant-...             # https://console.anthropic.com
# LLM_PROVIDER=gemini
# ORACLE_LLM_MODEL=gemini-2.5-flash        # or claude-sonnet-4-6

# Auto-challenger: oracle automatically stakes on mispriced open claims
# AUTO_CHALLENGE=1
# CHALLENGE_STAKE_USDC=2        # USDC per challenge (default: 2)
# CHALLENGE_CONFIDENCE=80       # min confidence % to auto-stake (default: 80)

# Fund both agent wallets with testnet USDC: https://faucet.circle.com

# ── Demo mode (no MetaMask needed) ───────────────────────────────────────────
# Enable demo relay: NEXT_PUBLIC_DEMO_MODE=1
# NEXT_PUBLIC_DEMO_MODE=1
# NEXT_PUBLIC_DEMO_MODE_LABEL=Arc Testnet demo

# Server-side demo signers (private keys on Arc Testnet)
# DEMO_CREATOR_PRIVATE_KEY=0x...
# DEMO_CHALLENGER_PRIVATE_KEY=0x...
# DEMO_SIGNER_PRIVATE_KEY=0x...     # fallback for all actions

# ── XMTP messaging (E2E encrypted chat) ──────────────────────────────────────
# NEXT_PUBLIC_XMTP_ENV=dev          # local | dev | production
# NEXT_PUBLIC_FEATURE_XMTP=1
# NEXT_PUBLIC_XMTP_APP_VERSION=mimir/0.1.0

# ── Mimir Council (10 AI personas as economic actors) ────────────────────────
# Generate the 10 persona wallets in one pass:
#   npm run council:create-wallets
# This populates CIRCLE_COUNCIL_<SLUG>_WALLET_ID + _ADDRESS pairs in this
# file for each of the ten personas. The worker is started with:
#   npm run council          # standalone
#   npm run workers          # bundled with oracle + market-creator
#
# Tunables (all optional; defaults are demo-friendly):
# COUNCIL_POLL_INTERVAL_MS=180000   # cycle interval in ms (default 3 min)
# COUNCIL_MAX_CLAIMS=12             # max claims per cycle, deadline-sorted
# COUNCIL_LLM_THROTTLE_MS=4500      # min ms between LLM calls
#
# The wallet pairs themselves look like this after the script runs
# (one block per persona; SLUG is the kebab→UPPER form of the persona id):
# CIRCLE_COUNCIL_OPTIMIST_WALLET_ID=
# CIRCLE_COUNCIL_OPTIMIST_ADDRESS=0x...
# CIRCLE_COUNCIL_PESSIMIST_WALLET_ID=
# CIRCLE_COUNCIL_PESSIMIST_ADDRESS=0x...
# CIRCLE_COUNCIL_CONTRARIAN_WALLET_ID=
# CIRCLE_COUNCIL_CONTRARIAN_ADDRESS=0x...
# CIRCLE_COUNCIL_STATISTICIAN_WALLET_ID=
# CIRCLE_COUNCIL_STATISTICIAN_ADDRESS=0x...
# CIRCLE_COUNCIL_WHALE_WATCHER_WALLET_ID=
# CIRCLE_COUNCIL_WHALE_WATCHER_ADDRESS=0x...
# CIRCLE_COUNCIL_CRYPTO_MAXI_WALLET_ID=
# CIRCLE_COUNCIL_CRYPTO_MAXI_ADDRESS=0x...
# CIRCLE_COUNCIL_SPORTS_PUNDIT_WALLET_ID=
# CIRCLE_COUNCIL_SPORTS_PUNDIT_ADDRESS=0x...
# CIRCLE_COUNCIL_WEATHERMAN_WALLET_ID=
# CIRCLE_COUNCIL_WEATHERMAN_ADDRESS=0x...
# CIRCLE_COUNCIL_DOOMER_WALLET_ID=
# CIRCLE_COUNCIL_DOOMER_ADDRESS=0x...
# CIRCLE_COUNCIL_YAPPER_WALLET_ID=
# CIRCLE_COUNCIL_YAPPER_ADDRESS=0x...

# ── Neon Postgres (server-side read index, optional) ─────────────────────────
# Contract state is always source of truth. Neon is a cache/read index used
# by /explorer, /dashboard, and the challenge-opportunities API. Mimir boots
# fine without it — the affected routes return 500 and other pages still work.
# Provision a free DB at https://console.neon.tech, then paste the
# pooler connection string here (it already includes ?sslmode=require).
# DATABASE_URL=postgresql://<user>:<pwd>@<host>/<db>?sslmode=require
# CRON_SECRET=

# ── Claim generation (AI-assisted create flow) ────────────────────────────────
# NEXT_PUBLIC_FEATURE_SOURCE_DRAFTS=1
# GEMINI_API_KEY=
# CLAIM_DRAFT_MODEL=gemini-2.5-flash

# ── Moderation ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_FEATURE_CLAIM_MODERATION=1
# CLAIM_MODERATION_MODEL=gemini-2.5-flash

# ══════════════════════════════════════════════════════════════════════════
# SOLANA × MAGICBLOCK ER × FLASH TRADE (primary runtime)
# ══════════════════════════════════════════════════════════════════════════

# ── Solana base layer ─────────────────────────────────────────────────────
# NEXT_PUBLIC_MIMIR_PROGRAM_ID=J9MZfzQt2LVkdfvqvTRPhcSN41gSmGKDWNVjxUQPxSDR
# NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
# Path to the agent/admin keypair JSON (solana-keygen format)
# SOLANA_KEYPAIR=~/.config/solana/talos-deploy.json
# Circle's official devnet USDC (6 decimals). Wallets are funded from
# https://faucet.circle.com → Solana Devnet (no local mint authority).
# SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ── MagicBlock Ephemeral Rollup ───────────────────────────────────────────
# Regional ER endpoint (or https://devnet-router.magicblock.app for routing)
# MAGICBLOCK_ER_RPC=https://devnet-as.magicblock.app/
# MAGICBLOCK_ER_WS=wss://devnet-as.magicblock.app/
# ER validator identity for DelegateConfig (Asia devnet default)
# MAGICBLOCK_ER_VALIDATOR=MAS1Dt9qreoRMQ14YQuhg8UTZMMzDdKhmkZMECCzk57

# ── Flash Trade (free public API, no key needed, 10 req/s) ────────────────
# Auto-hedge mode for the oracle's challenge stakes:
#   dry  = build the perp tx via Flash transaction-builder, log it, don't sign
#   live = sign + submit (Flash Trade runs on MAINNET — real funds!)
#   off  = no hedging
# HEDGE_MODE=dry

# ── Solana council worker ─────────────────────────────────────────────────
# COUNCIL_POLL_INTERVAL_MS=60000
# COUNCIL_FUND_USDC=25
# COUNCIL_PERSONA_LIMIT=0
